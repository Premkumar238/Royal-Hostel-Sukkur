# Supabase (required)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Platform title on login / browser tab
NEXT_PUBLIC_PLATFORM_NAME=Royal Girls Hostels

# Supabase Auth emails (must match users you create in Authentication)
NEXT_PUBLIC_HOSTEL1_LOGIN_EMAIL=royal-girls-hostel-1@hostel.local
NEXT_PUBLIC_HOSTEL2_LOGIN_EMAIL=royal-girls-hostel-2@hostel.local

# Passwords are set in Supabase Auth (not here):
# Hostel 1 → hostelpass1
# Hostel 2 → hostelpass2
