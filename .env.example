# Supabase (required)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Single-client app (optional)
# Display name on login and browser tab
NEXT_PUBLIC_APP_NAME=Royal Girls Hostel 1

# Lock app to one hostel row (UUID from Supabase hostels table). Leave empty to use the first hostel.
NEXT_PUBLIC_HOSTEL_ID=
