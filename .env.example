# Supabase (required)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Platform title on login / browser tab
NEXT_PUBLIC_PLATFORM_NAME=Royal Girls Hostels

# Supabase Auth (create these users in Authentication)
NEXT_PUBLIC_AUTH_LOGIN_DOMAIN=royalgirls.com
# Defaults: hostel1@royalgirls.com, hostel2@royalgirls.com

# Passwords are set in Supabase Auth (not here):
# Hostel 1 → hostelpass1
# Hostel 2 → hostelpass2
